    "postcss": "^8.4.0",
    "prettier": "^3.8.1",
    "stylelint": "^16.0.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{js,ts,html}": [
