# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
/dist

# misc
.DS_Store
*.local

# IDE
.vscode/*
!.vscode/extensions.json
.idea
*.swp
*.swo

# environment
.env
.env.local
.env.*.local
